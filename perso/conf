#!/bin/bash

########################  REQUIRED

_echot "------- required files"
file_env=${_path_base}/bs/conf/.sh_env
file_sh_aliases=${_path_base}/bs/conf/.sh_aliases
file_sh_functions=${_path_base}/bs/conf/.sh_functions
file_env_perso=${_path_base}/perso/conf/.sh_env_perso
_require ${file_env} ${file_sh_aliases} ${file_sh_functions} ${file_env_perso}

########################  SYSTEM

_echot "------- pacman France sources"
_evalr pacman-mirrors -c France

_echot "------- create paths"
pths="ext/backup ext/ovh ext/shared /home/shared"
for pth in ${pths}; do
	[ -d "${pth}" ] || _evalr mkdir -p ${pth}
	_evalr chown ${USER}:${USER} ${pth}
done

########################  SYSTEM

_echot "------- reduce swappiness"
_evalr swapoff -av
sudo sh -c 'echo vm.swappiness=20 > /etc/sysctl.d/99-swappiness.conf' # limit swap
_evalr swapon -v

########################  USER

_echot "------- .sh_env"
file=${HOME}/.sh_env
[ -h ${file} ] && _eval rm ${file}
_eval ln -s ${file_env} ${file}

_echot "------- .sh_aliases"
file=~/.sh_aliases
[ -h ${file} ] && _eval rm ${file}
_eval ln -s ${file_sh_aliases} ${file}

_echot "-------  .sh_functions"
file=~/.sh_functions
[ -h ${file} ] && _eval rm ${file}
_eval ln -s ${file_sh_functions} ${file}

_echot "------- .sh_env_perso"
file=${HOME}/.sh_env_perso
_keepmvts ${file}
_eval ln -s ${file_env_perso} ${file}

for file in ~/.bashrc ~/.zshrc; do
	_echot "------- ${file} env_perso"
	grep -q ".sh_env_perso" ${file} || echo "
# sh_env_perso
[ -f \${HOME}/.sh_env_perso ] && . \${HOME}/.sh_env_perso" >> ${file}
done

_echot "------- user links"
for file in .nanorc .tmux.conf .vimrc; do
	pth=${HOME}/${file}
	_keepmv "${pth}"
	_eval ln -s "${_PATH_BS}/conf/${file}" "${pth}"
done

_echot "------- language fr"
packages="hunspell-fr hyphen-fr mythes-fr tesseract-data-fra"
packages+=" firefox-i18n-fr libreoffice-still-fr"
${_CMD_INS} ${packages} && _partadd "${packages}" ${_FILE_PCK} \
	|| { _echoE "Unable to install: ${packages}"; return 1; }

_echot "------- git config"
git config --global user.name "aguy tech"
git config --global user.email aguytech@free.fr
git config --global core.editor vim
git config --global merge.tool meld

file=${HOME}/.gitconfig
grep -q '^[alias]' ${file} || echo -e "
[alias]
\tbr = branch
\tci = commit
\tco = checkout
\tdi = diff
\tst = status" >> ${file}
