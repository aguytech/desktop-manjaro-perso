#!/bin/bash

########################  REQUIRED

_echot "------- required files"
file_env=${_PATH_BASE}/bs/conf/.sh_env
file_sh_aliases=${_PATH_BASE}/bs/conf/.sh_aliases
file_sh_functions=${_PATH_BASE}/bs/conf/.sh_functions
_require ${file_env} ${file_sh_aliases} ${file_sh_functions}

########################  MAIN

_echot "------- .sh_aliases"
file=/root/.sh_aliases
file_from=${_PATH_BS}/conf/.sh_aliases
_keepmv ${file}
_evalr ln -s ${file_from} ${file}

_echot "------- .sh_env"
file=/root/.sh_env
file_from=${_PATH_BS}/conf/.sh_env
_keepmv ${file}
_evalr ln -s ${file_from} ${file}

_echot "------- .bashrc"
file="/root/.bashrc"
_keepcp ${file}

# force color
sudo sed -i '/^#force_color_prompt=/ s|#||' ${file}
# PS1
color='\\[\\033[01;31m\\]' # '\\[\\033[01;34m\\]'
sudo sed -i 's|^\(\s*PS1=\).*31m.*$|\1"'${color}'\\h\\[\\033[00m\\] \\W'${color}'#\\[\\033[00m\\] "|' ${file}
sudo sed -i "/^\s*PS1=.*31m/ s|\"|'|g" ${file}

sudo grep -q ".sh_env" ${file} || sudo sh -c "echo '
# global variables
[ -f /root/.sh_env ] && . /root/.sh_env

# functions
[ -f /root/.sh_functions ] && . /root/.sh_functions
' >> ${file}"
# aliases
sudo grep -q "/.sh_aliases" ${file} || sudo sh -c "echo '
# sh_aliases
[ -f /root/.sh_aliases ] && . /root/.sh_aliases
'  >> ${file}"

_echot "------- .vimrc"
file=/root/.vimrc
file_from=${_PATH_BS}/conf/.vimrc
_keepmv ${file}
_evalr ln -s ${file_from} ${file}
